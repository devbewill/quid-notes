        <div className="font-mono text-xl space-y-4 mt-4">
          <div className="text-[#666666]">
            📁 Documents
          </div>
          <div className="text-[#444444] ml-8">
            📁 Projects
          </div>
          <div className="text-[#333333] ml-16">
            📁 2024
          </div>
          <div className="text-[#222222] ml-24">
            📁 Q1
          </div>
          <div className="text-[#FF4D00] ml-32">
