function GlitchBackground() {
  const isMounted = useRef(false);

  useEffect(() => {
    isMounted.current = true;
  }, []);

  return (
    <div className="absolute inset-0 overflow-hidden pointer-events-none">
      <div className="absolute inset-0 bg-[linear-gradient(0deg,transparent_24%,rgba(255,0,255,0.05)_25%,rgba(255,0,255,0.05)_26%,transparent_27%,transparent_74%,rgba(0,255,0,0.05)_75%,rgba(0,255,0,0.05)_76%,transparent_77%,transparent),linear-gradient(90deg,transparent_24%,rgba(255,77,0,0.05)_25%,rgba(255,77,0,0.05)_26%,transparent_27%,transparent_74%,rgba(255,255,0,0.05)_75%,rgba(255,255,0,0.05)_76%,transparent_77%,transparent)] bg-[length:50px_50px]" />

      {!isMounted.current && <div style={{ position: 'absolute', left: `${Math.random() * 100}%`, top: `${Math.random() * 100}%` }} />}

      {isMounted.current && [...Array(5)].map((_, i) => {
        const seed = i * 1000;
        const left = ((seed * 9301 + 49297) % 233280) / 233280 * 100;
        const top = ((seed * 49297 + 9301) % 233280) / 233280 * 100;
        const animX = ((seed * 12345) % 20000 - 10000) / 100;
        const animY = ((seed * 67890) % 20000 - 10000) / 100;
        const duration = 3 + ((seed * 54321) % 20000) / 10000;

        return (
          <motion.div
            key={i}
            animate={{
              x: [0, animX, 0],
              y: [0, animY, 0]
            }}
            transition={{
              duration,
              repeat: Number.POSITIVE_INFINITY,
              ease: "linear"
            }}
            className="absolute w-1 h-1 bg-[#FF4D00]"
            style={{
              left: `${left}%`,
              top: `${top}%`
            }}
          />
        );
      })}

      {isMounted.current && [...Array(5)].map((_, i) => {
        const seed = (i + 10) * 1000;
        const left = ((seed * 9301 + 49297) % 233280) / 233280 * 100;
        const top = ((seed * 49297 + 9301) % 233280) / 233280 * 100;
        const animX = ((seed * 12345) % 20000 - 10000) / 100;
        const animY = ((seed * 67890) % 20000 - 10000) / 100;
        const duration = 4 + ((seed * 54321) % 20000) / 10000;

        return (
          <motion.div
            key={`c${i}`}
            animate={{
              x: [0, animX, 0],
              y: [0, animY, 0]
            }}
            transition={{
              duration,
              repeat: Number.POSITIVE_INFINITY,
              ease: "linear"
            }}
            className="absolute w-1 h-1 bg-[#FF00FF]"
            style={{
              left: `${left}%`,
              top: `${top}%`
            }}
          />
        );
      })}

      {isMounted.current && [...Array(5)].map((_, i) => {
          key={`g${i}`}
          animate={{ 
            x: [0, Math.random() * 100 - 50, 0],
            y: [0, Math.random() * 100 - 50, 0]
          }}
          transition={{ 
            duration: 5 + Math.random() * 2,
            repeat: Number.POSITIVE_INFINITY,
            ease: "linear"
          }}
          className="absolute w-1 h-1 bg-[#00FF00]"
          style={{
            left: `${Math.random() * 100}%`,
            top: `${Math.random() * 100}%`
          }}
        />
      ))}
    </div>
  );
}

function BrutalMarquee() {
  const text = "NO FOLDERS • NO BULLSHIT • AI POWERED • REAL-TIME • ";
  return (
    <div className="flex overflow-hidden">
      <motion.div
        animate={{ x: ["0%", "-50%"] }}
        transition={{ repeat: Number.POSITIVE_INFINITY, ease: "linear", duration: 20 }}
        className="flex whitespace-nowrap"
      >
        {[...Array(6)].map((_, i) => (
          <span key={i} className="text-6xl md:text-8xl font-black text-[#000000] px-8 uppercase">
            {text}
          </span>
        ))}
      </motion.div>
    </div>
  );
}

